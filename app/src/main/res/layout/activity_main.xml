<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/yp_blue"
    android:orientation="vertical"
    android:paddingHorizontal="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_string"
        android:textColor="@color/white"
        android:textSize="@dimen/main_text_size"
        android:layout_marginTop="14dp"/>

    <Button
        android:id="@+id/search_button_pm"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="40dp"
        android:layout_weight="1"
        android:backgroundTint="@color/white"
        android:letterSpacing="0"
        android:text="@string/search_button"
        android:textAllCaps="false"
        android:textColor="@color/yp_black"
        android:textSize="@dimen/main_text_size"
        app:cornerRadius="@dimen/main_button_corner_radius"
        app:icon="@drawable/ic_loopa"
        app:iconGravity="textStart"
        app:iconPadding="@dimen/main_button_icon_padding"
        app:iconTint="@color/yp_black"
        android:insetBottom="0dp"
        android:insetTop="0dp"

        />

    <Button
        android:id="@+id/media_button_pm"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/main_button_margin_side"
        android:layout_weight="1"
        android:backgroundTint="@color/white"
        android:letterSpacing="0"
        android:text="@string/media_button"
        android:textAllCaps="false"
        android:textColor="@color/yp_black"
        android:textSize="@dimen/main_text_size"
        app:cornerRadius="@dimen/main_button_corner_radius"
        app:icon="@drawable/ic_media"
        app:iconGravity="textStart"
        app:iconPadding="@dimen/main_button_icon_padding"
        app:iconTint="@color/yp_black"
        android:insetBottom="0dp"
        android:insetTop="0dp"
        />

    <Button
        android:id="@+id/pref_button_pm"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/main_button_margin_side"
        android:layout_weight="1"
        android:backgroundTint="@color/white"
        android:letterSpacing="0"
        android:text="@string/pref_button"
        android:textAllCaps="false"
        android:textColor="@color/yp_black"
        android:textSize="@dimen/main_text_size"
        app:cornerRadius="@dimen/main_button_corner_radius"
        app:icon="@drawable/ic_gear"
        app:iconGravity="textStart"
        app:iconPadding="@dimen/main_button_icon_padding"
        app:iconTint="@color/yp_black"
        android:insetBottom="0dp"
        android:insetTop="0dp"


        />

</LinearLayout>